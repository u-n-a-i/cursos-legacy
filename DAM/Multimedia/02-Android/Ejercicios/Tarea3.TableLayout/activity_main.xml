<?xml version="1.0" encoding="utf-8"?>
<TableLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:stretchColumns="1"
    android:padding="20dp"
    tools:context=".MainActivity">


    <!-- Encabezados de la tabla -->
    <TableRow
        android:background="#41A67E">

        <TextView
            android:layout_weight="1"
            android:text="Producto"
            android:textColor="#fff"
            android:textStyle="bold" />

        <TextView
            android:layout_weight="1"
            android:text="Subtotal"
            android:textColor="#fff"
            android:gravity="end"
            android:textStyle="bold" />
    </TableRow>

    <!-- Filas de productos -->
    <TableRow>
        <TextView android:text="Jabón de manos x 1" />
        <TextView android:text="2€" android:gravity="end" />
    </TableRow>

    <TableRow>
        <TextView android:text="Shampoo Monster x 1" />
        <TextView android:text="9,50€" android:gravity="end" />
    </TableRow>

    <TableRow>
        <TextView android:text="Pastas Dulcesol x 2" />
        <TextView android:text="5,40€" android:gravity="end" />
    </TableRow>

    <TableRow>
        <TextView android:text="Café Mezcla 250gr x 1" />
        <TextView android:text="1,70€" android:gravity="end" />
    </TableRow>

    <!-- Línea -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#BDBDBD"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp" />

    <!-- Subtotales -->
    <TableRow>
        <TextView
            android:text="Subtotal"
            android:textStyle="bold"
            android:gravity="end"
            android:textColor="#009688"/>
        <TextView
            android:text="18,6€"
            android:gravity="end"
            android:textStyle="bold" />
    </TableRow>

    <TableRow>
        <TextView
            android:text="Gastos de envío"
            android:textStyle="bold"
            android:gravity="end"
            android:textColor="#009688" />
        <TextView
            android:text="3€"
            android:gravity="end" />
    </TableRow>

    <TableRow>
        <TextView
            android:text="Descuento"
            android:textStyle="bold"
            android:gravity="end"
            android:textColor="#009688" />
        <TextView
            android:text="-2€"
            android:gravity="end" />
    </TableRow>

    <TableRow>
        <TextView
            android:text="Total"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_width="100dp"
            android:textColor="#009688" />
        <TextView
            android:text="16,6€"
            android:textStyle="bold"
            android:gravity="end" />
    </TableRow>

</TableLayout>

