<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#FFF8FB"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvNumeroPregunta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/numero_pregunta"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="#4A148C" />

    <TextView
        android:id="@+id/tvPregunta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvNumeroPregunta"
        android:layout_marginTop="20dp"
        android:text="@string/ejemplo_pregunta"
        android:textSize="18sp"
        android:textColor="#000000" />

    <RadioGroup
        android:id="@+id/grupoOpciones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvPregunta"
        android:layout_marginTop="24dp">

        <RadioButton
            android:id="@+id/opcion1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/opcion1" />

        <RadioButton
            android:id="@+id/opcion2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/opcion2" />

        <RadioButton
            android:id="@+id/opcion3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/opcion3" />

        <RadioButton
            android:id="@+id/opcion4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/opcion4" />
    </RadioGroup>

    <Button
        android:id="@+id/btnSiguiente"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:text="@string/siguiente"
        android:backgroundTint="#7E57C2"
        android:textColor="@android:color/white" />
</RelativeLayout>

