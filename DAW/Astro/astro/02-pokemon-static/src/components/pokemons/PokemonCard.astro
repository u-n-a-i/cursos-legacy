---
interface Props {
  name: string;
  url: string;
  isBig?: boolean;
}

const { name, url, isBig = false } = Astro.props;
const id = url.split("/").at(-2);
const imageSrc = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/shiny/${id}.png`;
---

<!-- href={`/pokemons/${name}`} -->
<a
  href={`/pokemon/${id}`}
  class:list={[
    `rounded flex flex-col justify-center items-center p-2`,
    {
      border: !isBig,
    },
  ]}
>
  <img src={imageSrc} alt={name} transition:name=`${name}-image` />
  <span
    class:list={[
      `capitalize`,
      {
        "text-3xl text-blue-300": isBig,
      },
    ]}>#{id} {name}</span
  >
</a>

